# ─── LLM Provider ─────────────────────────────────────────────────────────
# Pick any provider supported by the Vercel AI SDK. Swap by changing these —
# no code changes needed.
#   google               — Gemini (default)
#   openai               — OpenAI (GPT-4o, o1, etc.)
#   anthropic            — Claude
#   openai-compatible    — any OpenAI-compatible endpoint (LiteLLM, OpenRouter,
#                          Ollama, vLLM, TGI, LocalAI…). Set LLM_API_BASE too.
LLM_PROVIDER=google
LLM_MODEL=gemini-3.1-flash-lite-preview
LLM_API_KEY=

# Only for LLM_PROVIDER=openai-compatible
#   http://litellm:4000/v1            (LiteLLM proxy)
#   http://localhost:11434/v1         (Ollama)
#   https://openrouter.ai/api/v1      (OpenRouter)
LLM_API_BASE=

# ─── Tavily Web Search (optional — enables web search in agent research) ──
# Get a key at: https://tavily.com/
TAVILY_API_KEY=

# ─── HuggingFace Hub access token (optional — for gated models) ───────────
# Get a token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ─── Google OAuth (optional — for Google login support) ───────────────────
# Set up at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Server Port ─────────────────────────────────────────────────────────
# Port the Nexus web server listens on (default: 7777)
PORT=7777

# ─── Pre-built Client Binaries Host ──────────────────────────────────────
# Where the Downloads page fetches the client apps (.apk / .AppImage / .zip /
# .tar.gz) from. Default points at the public GitHub Release. Repoint at any
# HTTPS host that serves the same filenames — your fork's release, R2, S3,
# GitLab generic packages, etc.
NEXT_PUBLIC_RELEASES_BASE=https://github.com/pavancshekar-dev/nexus-clients/releases/download/clients-v1
