# QpiAI Nexus — Environment Configuration
# Copy this file to .env and fill in your keys.

# Gemini 2.0 Flash API Key (required for AI agent workflow)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Tavily Web Search API Key (optional — enables web search in agent research)
# Get a key at: https://tavily.com/
TAVILY_API_KEY=

# HuggingFace Hub Access Token (optional — for downloading gated models)
# Get token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Google OAuth (optional — for Google login support)
# Set up at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Python venv setup (Docker only)
# Controls which ML environments are installed on first run:
#   gguf       — GGUF quantization only (recommended, ~1GB)
#   gguf,awq   — GGUF + AWQ
#   all        — all methods (~3GB)
#   (empty)    — skip, start without ML
SETUP_VENVS=gguf
