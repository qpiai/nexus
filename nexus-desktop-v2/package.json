{
  "name": "nexus-desktop-v2",
  "version": "2.1.0",
  "description": "QpiAI Nexus Desktop v2 - On-device LLM inference via llama-server",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --linux",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux",
    "build-mac": "electron-builder --mac",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.nexus.desktop",
    "productName": "QpiAI Nexus",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico",
      "extraResources": [
        { "from": "bin/win-x64/", "to": "bin/", "filter": ["**/*"] }
      ]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "extraResources": [
        { "from": "bin/linux-x64/", "to": "bin/", "filter": ["**/*"] }
      ]
    },
    "mac": {
      "target": [{ "target": "zip", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "icon": "assets/icon-512.png",
      "artifactName": "QpiAI-Nexus-macOS-${arch}-${version}.${ext}",
      "extraResources": [
        { "from": "bin/darwin-${arch}/", "to": "bin/", "filter": ["**/*"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
